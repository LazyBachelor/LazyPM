{
    "editor.quickSuggestions": {
        "strings": "on"
    },
    "editor.formatOnSave": true,
    "[templ]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "a-h.templ"
    },
    "tailwindCSS.includeLanguages": {
        "css": "css",
        "templ": "html"
    },
    "emmet.includeLanguages": {
        "templ": "html"
    },
    "files.associations": {
        "*.css": "postcss"
    },
    "editor.colorDecorators": true,
    "editor.defaultColorDecorators": "always"
}